# ── Supabase (PostgREST + pgvector) ───────────────────────────────────────────
# The app talks to Supabase via the PostgREST client using the anon key.
SUPABASE_URL=
SUPABASE_ANON_KEY=

NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# ── OpenAI (LLM + Embeddings — single key for both) ──────────────────────────
OPENAI_API_KEY=
LLM_CHOICE=
INGESTION_LLM_CHOICE=
EMBEDDING_MODEL=
APP_ENV=development
LOG_LEVEL=INFO
APP_PORT=8058

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_PRIVATE_BUCKET=
S3_PUBLIC_BUCKET=

# Access Control Configuration
# Users who can access PRIVATE documents (comma-separated)
PRIVATE_DOCUMENT_USERS=

# Admin users (comma-separated) - can access all documents
ADMIN_USERS=

# JWT Configuration
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Celery + Redis (async task queue) ─────────────────────────────────────────
# Use the docker service hostname for compose; localhost for a bare local run.
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
# Optional independent overrides (default to REDIS_URL):
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TIMEZONE=UTC
# Periodic S3 ingest sweep interval (minutes) and on/off switch for Beat.
INGEST_INTERVAL_MINUTES=15
AUTO_INGEST_ENABLED=true

# ── Session memory ────────────────────────────────────────────────────────────
# redis = history shared across all api/worker processes (recommended);
# memory = per-process in-memory (fine for a single process / local dev).
SESSION_MEMORY_BACKEND=redis
SESSION_TTL_SECONDS=86400           # rolling per-session expiry (24h); not permanent
CONTEXT_WINDOW_TURNS=10             # sliding window: last N user+assistant turns
SESSION_KEY_PREFIX=uchenab:session:

# ── App networking (consumed by docker-compose) ───────────────────────────────
APP_HOST=0.0.0.0
# APP_PORT is defined above; REDIS_PORT exposes Redis on the host.

# CORS allow-list (comma-separated origins). Never "*". Add your deployed
# frontend origin(s); defaults cover the local Vite/React dev servers.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Guardrails ────────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
ENFORCE_ROMAN_URDU=true          # transliterate any Hindi/Devanagari output → Roman Urdu
GUARDRAIL_MAX_INPUT_CHARS=4000
GUARDRAIL_MIN_INPUT_CHARS=1

# ── WhatsApp Cloud API (Meta Graph API) ───────────────────────────────────────
# See README_WHATSAPP_VOICE.md → "WhatsApp Cloud API setup" for how to obtain these.
WHATSAPP_ACCESS_TOKEN=          # Permanent / system-user access token
WHATSAPP_PHONE_NUMBER_ID=       # The Phone number ID (NOT the phone number)
WHATSAPP_BUSINESS_ACCOUNT_ID=   # WhatsApp Business Account (WABA) ID
WHATSAPP_APP_SECRET=            # App secret — verifies inbound webhook signatures
WHATSAPP_VERIFY_TOKEN=          # Any random string; paste the same value in Meta UI
WHATSAPP_API_VERSION=v21.0      # Graph API version

# ── Deepgram (voice-note transcription) ───────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=multi         # multi = Roman-Urdu + English code-switching
